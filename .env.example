# ── Database ──────────────────────────────────────────────────────────────────
# Neon serverless Postgres — pooled connection for API routes
DATABASE_URL=postgresql://your-neon-user:your-neon-password@your-neon-host-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Neon direct (non-pooled) — used only by drizzle-kit for migrations
DATABASE_URL_DIRECT=postgresql://your-neon-user:your-neon-password@your-neon-host.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Supabase Auth ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ── Cloudflare R2 (screenshot storage, S3-compatible) ─────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET=tradecore-screenshots
# Public CDN URL for your R2 bucket (custom domain or r2.dev URL)
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-public-url.example.com

# ── Upstash Redis (background job queuing) ────────────────────────────────────
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-upstash-redis-token

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Internal API protection ───────────────────────────────────────────────────
# Random string — generate with: openssl rand -hex 32
INTERNAL_API_SECRET=replace-with-random-32-char-hex-string

# ── Admin panel ───────────────────────────────────────────────────────────────
# Secret URL path segment that gates the admin panel — never share, never commit the real value.
ADMIN_PANEL_PATH=replace-with-a-secret-path-only-you-know
